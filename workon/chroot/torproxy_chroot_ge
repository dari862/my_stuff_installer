#!/bin/sh

__ControlPort=9051
__DNSPort=5353
__SocksPort=9050
__TransPort=9040

# Create a directory for the chroot environment
mkdir -p /mnt/tor-chroot

# Debootstrap the chroot environment
debootstrap --arch amd64 --variant=minbase bullseye /mnt/tor-chroot

# Chroot into the environment and install packages
chroot /mnt/tor-chroot /bin/bash <<- EOF
# Install essential packages
apt update
apt install -y tor

# Configure Tor
echo "AutomapHostsOnResolve 1" >> /etc/tor/torrc
echo "ControlPort $__ControlPort" >>/etc/tor/torrc
echo "ControlSocket /etc/tor/run/control" >>/etc/tor/torrc
echo "ControlSocketsGroupWritable 1" >>/etc/tor/torrc
echo "CookieAuthentication 1" >>/etc/tor/torrc
echo "CookieAuthFile /etc/tor/run/control.authcookie" >>/etc/tor/torrc
echo "CookieAuthFileGroupReadable 1" >>/etc/tor/torrc
echo "DNSPort $__DNSPort" >>/etc/tor/torrc
echo "DataDirectory /var/lib/tor" >>/etc/tor/torrc
echo "ExitPolicy reject *:*" >>/etc/tor/torrc
echo "Log notice stderr" >>/etc/tor/torrc
echo "RunAsDaemon 0" >>/etc/tor/torrc
echo "SocksPort $__SocksPort IsolateDestAddr" >>/etc/tor/torrc
echo "TransPort $__TransPort" >>/etc/tor/torrc
echo "VirtualAddrNetworkIPv4 10.192.0.0/10" >>/etc/tor/torrc

# Start Tor on boot
update-rc.d tor defaults

# Create a user to run Tor
useradd -m -s /bin/bash toruser
EOF

# Create a script to start Tor in the background
cat > /mnt/tor-chroot/etc/init.d/start-tor <<- EOF
#!/bin/bash
su - toruser -c "tor -D /var/log/tor/log -f /etc/tor/torrc"
EOF

# Make the script executable
chroot /mnt/tor-chroot chmod +x /etc/init.d/start-tor

# Start Tor on boot
chroot /mnt/tor-chroot update-rc.d start-tor defaults

# Mount the chroot environment
mount -t proc /proc /mnt/tor-chroot/proc
mount -t sysfs /sys /mnt/tor-chroot/sys
mount -t devpts /dev /mnt/tor-chroot/dev

# Run the script to start Tor
chroot /mnt/tor-chroot /etc/init.d/start-tor start
