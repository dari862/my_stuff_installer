do_you_want_2_run_this_yes_or_no(){
	massage_is_="${1}"
	yn=""
	read -r -p "${massage_is_} (yes/no) " yn
	yn="${yn^^}"
	[ "$yn" = "YES" ] && yn="Y"
	echo "$yn"
}
