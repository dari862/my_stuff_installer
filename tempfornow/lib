## functions
show_m()
{
  echo -e $'\033[1;32m'"$*"$'\033[0m'
}

show_em()
{
	__massage="${1-}"
	echo "$__massage"
}

check_and_run_else_download_and_run()
{
  check_this_file_="${1-}"
  if [ ! -f "$check_this_file_" ]; then
  	show_em "Error: Failed to locate $check_this_file_ ."
	wget -q https://raw.githubusercontent.com/dari862/my_stuff_installer/main/tempfornow/"$check_this_file_" || show_em "Error: Failed to download $check_this_file_ ."
	chmod +x "$check_this_file_"
	if [ ! -f "$check_this_file_" ]; then
		show_em "Error: Failed to locate $check_this_file_ ."
		exit 1
	fi
fi
}

aptupdate()
{
	show_m "updating your system"
	if ! command -v sudo >/dev/null
	then
		[ "$(find /var/cache/apt/pkgcache.bin -mtime 0 2>/dev/null)" ] || apt-get update
		apt-get update
	else
		[ "$(find /var/cache/apt/pkgcache.bin -mtime 0 2>/dev/null)" ] || sudo apt-get update
		sudo apt-get update
	fi
}

aptfixer()
{
	if ! command -v sudo >/dev/null
	then
		### Fix broken packages for good measure (why not?)
		$aptinstall -f 2>/dev/null || show_em "failed to $sudoaptinstall -f"
	else
		### Fix broken packages for good measure (why not?)
		$sudoaptinstall -f 2>/dev/null || show_em "failed to $sudoaptinstall -f"
	fi
}

check_for_SUDO()
{
	if ! command -v sudo >/dev/null
	then
		show_m "Install sudo and add user 1000 to sudo group"
		$aptinstall sudo
		user=$(cut -f 1,3 -d: /etc/passwd | grep :1000$ | cut -f1 -d:)
		[ "$user" ] && adduser "$user" sudo
	fi
}

must_install_apps()
{
	$aptinstall psmisc locate git || (show_em "failed to install psmisc for (killall) command or locate or git." && exit 1)
}

kill_apt()
{
	sudo killall -9 apt &>/dev/null || sudo killall -9 apt-get &>/dev/null || :
}

upgrade_now()
{
	sudo DEBIAN_FRONTEND=noninteractive apt-get -y upgrade
}

_unattended_upgrades_()
{
	auto_upgrades_file="/etc/apt/apt.conf.d/20auto-upgrades"
	if [ -f "${auto_upgrades_file}" ];then
		auto_upgrades_file_bak="/etc/apt/apt.conf.d/20auto-upgrades.bak"
		case "$1" in
			start)
					sudo systemctl stop unattended-upgrades || :
				if [ ! -f "${auto_upgrades_file_bak}" ];then
					sudo mv "${auto_upgrades_file}" "${auto_upgrades_file_bak}"
				fi
			;;
			stop)
				if [ -f "${auto_upgrades_file}" ] && [ -f "${auto_upgrades_file_bak}" ];then
					sudo rm "${auto_upgrades_file}"
				fi
					
				if [ -f "${auto_upgrades_file_bak}" ];then
					sudo mv "${auto_upgrades_file_bak}" "${auto_upgrades_file}"
				fi
			;;
		esac
	fi
}

rm_if_link()
