#!/bin/bash
set -e

if ! test_if_my_stuff_lib_sourced 2>/dev/null; then
	# source lib
	temp_path="/tmp/my_stuff"
	mkdir -p "${temp_path}"
	my_stuff_lib_location="$(find $HOME -type f -name my_stuff_lib | head -1 || :)"
	if [[ ! -z "${my_stuff_lib_location}" ]];then
		mv "${my_stuff_lib_location}" "${temp_path}"
	fi
	
	if ! source "${temp_path}"/my_stuff_lib 2> /dev/null; then
		echo "wget lib file"
		wget -q https://raw.githubusercontent.com/dari862/my_stuff_installer/main/tempfornow/my_stuff_lib
		if ! source "${temp_path}"/my_stuff_lib 2> /dev/null; then
			echo "Error: Failed to source my_stuff_lib from ${temp_path}" >&2
			exit 1
		fi
	fi
fi

install_GPU_now="${1-}"
list_of_apps_file_path="$(mktemp "${temp_path}"/list_of_apps_.XXXXXXXXXXXX)"

##################################################################################
# function
##################################################################################
create_apt_list(){
	apt list 2>/dev/null > "${list_of_apps_file_path}" 
}

apt_install_()
{
	$sudoaptinstall "${List_of_apt_2_install_[@]}"
}

add_2_apt_install_()
{
	localarray=("$@")

	for INDEX in "${localarray[@]}"
	do
		if ! dpkg -s "${INDEX}" > /dev/null 2>&1; then
			if grep "^${INDEX}/" ${list_of_apps_file_path};then
				List_of_apt_2_install_+=("$INDEX") 
				show_m "${INDEX} added to install apps" 
			fi
		fi
	done
}

##################################################################################
# var
##################################################################################

List_of_apt_2_install_=()

#######################
## must_install_apps_list
#######################
#must have apps
install_audio=(pulseaudio pavucontrol)
install_if_laptop=(acpi upower)
if [[ "$(ls /sys/class/backlight | head -n 1)" == *"intel_"* ]]; then
	install_if_laptop+=(xbacklight)
else
	install_if_laptop+=(light)
fi
install_wireless=(wireless-tools)
install_Network=(rfkill network-manager network-manager-gnome)
install_bluetooth=(bluez blueman)
install_autoinstall_firmware=(isenkram)
install_test=(avahi-utils coinor-libcbc3 coinor-libcgl1 coinor-libclp1 coinor-libcoinmp1v5 coinor-libcoinutils3v5 coinor-libosi1v5 cups-pk-helper espeak-ng-data exfalso fonts-font-awesome fonts-lato fonts-opensymbol gimp-data gir1.2-atspi-2.0 gir1.2-gst-plugins-base-1.0 gir1.2-gstreamer-1.0 gir1.2-gtksource-3.0 gir1.2-handy-1 gir1.2-javascriptcoregtk-4.0 gir1.2-packagekitglib-1.0 gir1.2-polkit-1.0 gir1.2-secret-1 gir1.2-soup-2.4 gir1.2-webkit2-4.0 gir1.2-wnck-3.0 gstreamer1.0-gtk3 hyphen-en-us libabw-0.1-1 libamd2 libatk-adaptor libbabl-0.1-0 libboost-iostreams1.74.0 libbox2d2 libbrlapi0.8 libcamd2 libccolamd2 libcdr-0.1-1 libcholmod3 libclucene-contribs1v5 libclucene-core1v5 libcolamd2 libdotconf0 libe-book-0.1-1 libeot0 libepubgen-0.1-1 libespeak-ng1 libetonyek-0.1-1 libexttextcat-2.0-0 libexttextcat-data libfreehand-0.1-1 libgegl-0.4-0 libgegl-common libgexiv2-2 libgimp2.0 libgpgmepp6 libgtksourceview-3.0-1 libgtksourceview-3.0-common libjavascriptcoregtk-4.0-18 liblangtag-common liblangtag1 libmetis5 libmhash2 libmspub-0.1-1 libmwaw-0.3-3 libmythes-1.2-0 libnma-common libnma0 libnumbertext-1.0-0 libnumbertext-data libodfgen-0.1-1 liborcus-0.17-0 liborcus-parser-0.17-0 libpackagekit-glib2-18 libpagemaker-0.0-0 libpcaudio0 libqxp-0.0-0 librasqal3 libraw20 librdf0 libreoffice-base-core libreoffice-calc libreoffice-common libreoffice-core libreoffice-draw libreoffice-gtk3 libreoffice-help-common libreoffice-help-en-us libreoffice-impress libreoffice-math libreoffice-style-colibre libreoffice-writer librevenge-0.0-0 libsonic0 libsoup-gnome2.4-1 libspeechd2 libstaroffice-0.0-0 libsuitesparseconfig5 libumfpack5 libuno-cppu3 libuno-cppuhelpergcc3-3 libuno-purpenvhelpergcc3-3 libuno-sal3 libuno-salhelpergcc3-3 libvisio-0.1-1 libwebkit2gtk-4.0-37 libwpd-0.10-10 libwpg-0.3-3 libwps-0.4-4 libxmlsec1 libxmlsec1-nss libzmf-0.0-0 lp-solve mobile-broadband-provider-info mythes-en-us network-manager-gnome node-clipboard node-normalize.css node-prismjs orca perl-tk python3-brlapi python3-cups python3-cupshelpers python3-feedparser python3-louis python3-musicbrainzngs python3-pyatspi python3-pyinotify python3-sgmllib3k python3-smbc python3-speechd python3-uno quodlibet sound-icons speech-dispatcher speech-dispatcher-audio-plugins speech-dispatcher-espeak-ng sphinx-rtd-theme-common system-config-printer system-config-printer-common system-config-printer-udev uno-libs-private ure xbrlapi xkbset xsane xsane-common)

##################################################################################
# GPU Drivers
##################################################################################
if [[ "${install_GPU_now}" = "install_GPU" ]];then
	if [ "$(lspci | grep "VGA compatible controller" | grep VMware -c)" != "0" ];then
		echo "This is VM"
	else
		if [ -f /etc/os-release ]; then
    		# freedesktop.org and systemd
    		. /etc/os-release
    		version_=$(echo "${VERSION_ID//./}")
    		distro_name_="$ID"
    		distro_name_and_ver_=$ID$version_
		elif [ -f /etc/lsb-release ]; then
    		# For some versions of Debian/Ubuntu without lsb_release command
    		. /etc/lsb-release
    		distro_name_="$DISTRIB_ID"
    		distro_name_and_ver_=$DISTRIB_ID$DISTRIB_RELEASE
		else
    		# Fall back to uname, e.g. "Linux <version>", also works for BSD, etc.
    		distro_name_="$(uname -s)"
    		distro_name_and_ver_=$(uname -s)$(uname -r)
		fi
		
		if [ "${nvidia_gpu_exist}" = "true" ];then
			_cuda_="${2-}"
			_kernel_open_dkms_="${3-}"
			add_2_apt_install_ "nvidia-driver nvidia-smi nvidia-settings $_kernel_open_dkms_ $_cuda_"
		fi
		
		if [ "${amd_gpu_exist}" = "true" ];then
			add_2_apt_install_ "libgl1-mesa-dri xserver-xorg-video-ati xserver-xorg-video-amdgpu mesa-vulkan-drivers vkbasalt"
		fi
		
		if [ "${intel_gpu_exist}" = "true" ];then
			add_2_apt_install_ "xserver-xorg-video-intel intel-gpu-tools intel-media-va-driver"
		fi
	fi
fi

##################################################################################
# main
##################################################################################
create_apt_list # needed for add_2_apt_install_

if [[ "$(CHECK_IF_THIS_LAPTOP)"  = true ]];then
	add_2_apt_install_ "${install_if_laptop[@]}"
fi

if lspci | egrep -i 'wifi|wireless' 1>/dev/null ;then
	add_2_apt_install_ "${install_wireless[@]}"
fi

if sudo dmesg | grep -i bluetooth 1>/dev/null || sudo lsusb | grep -i bluetooth 1>/dev/null ;then
	add_2_apt_install_ "${install_bluetooth[@]}"
fi

add_2_apt_install_ "${install_audio[@]}"
add_2_apt_install_ "${install_Network[@]}"
add_2_apt_install_ "${install_autoinstall_firmware[@]}"
add_2_apt_install_ "${install_test[@]}"

if [[ "${install_GPU_now}" = "install_GPU" ]];then
	if [ "${nvidia_gpu_exist}" = "true" ];then
		if [[ ! -f "/usr/share/keyrings/nvidia-drivers.gpg" ]];then
			curl -fSsL "https://developer.download.nvidia.com/compute/cuda/repos/$distro_name_and_ver_/x86_64/3bf863cc.pub" | sudo gpg --dearmor | sudo tee /usr/share/keyrings/nvidia-drivers.gpg > /dev/null 2>&1
		fi
		
		if [[ ! -f "/etc/apt/sources.list.d/nvidia-drivers.list" ]];then 
			echo "deb [signed-by=/usr/share/keyrings/nvidia-drivers.gpg] https://developer.download.nvidia.com/compute/cuda/repos/$distro_name_and_ver_/x86_64/ /" | sudo tee /etc/apt/sources.list.d/nvidia-drivers.list
		fi
	fi
fi
		
if [ "$distro_name_" = "ubuntu" ];then
	sudo apt-get install -y software-properties-common
	sudo add-apt-repository -y universe
	sudo add-apt-repository -y multiverse
	show_m "Running Update."
	aptupdate
else
	show_m "Running Update."
	aptupdate
fi
		
apt_install_

if [[ "$(CHECK_IF_THIS_LAPTOP)"  = true ]];then
	show_m "this is laptop"
	if [ "$number_of_gpus" -gt 1 ]; then
		show_m "create envycontrol installtion file."
cat << 'EOF' > "${temp_path}"/envycontrol_updater_DmDmDmdMdMdM
	envycontrol_updater_path="$(mktemp -d)" 
	__Custom_distro_dir_name="DmDmDmdMdMdM"
	wget -qO- 'https://api.github.com/repos/bayasdev/envycontrol/releases/latest' \
  	| grep '"tarball_url"' \
  	| cut -f2,3 -d':' \
  	| tr -d '"' \
  	| tr -d ',' \
  	| xargs wget -O "${envycontrol_updater_path}"/envycontrol.tar.gz && tar -xvzf "${envycontrol_updater_path}"/envycontrol.tar.gz -C "${envycontrol_updater_path}" && mv "${envycontrol_updater_path}"/bayasdev* "${envycontrol_updater_path}"/envycontrol
  	
  	[ -d "/usr/share/${__Custom_distro_dir_name}/opt/downloaded/envycontrol" ] && sudo rm -rdf "/usr/share/${__Custom_distro_dir_name}/opt/downloaded/envycontrol"
  	[ ! -d "/usr/share/${__Custom_distro_dir_name}/opt/downloaded" ] && sudo mkdir -p /usr/share/${__Custom_distro_dir_name}/opt/downloaded
  	[ ! -d "/usr/share/${__Custom_distro_dir_name}/opt/git" ] && sudo mkdir -p /usr/share/${__Custom_distro_dir_name}/opt/git
  	
  	if [ -d "${envycontrol_updater_path}"/envycontrol ];then
  		chmod +x "${envycontrol_updater_path}"/envycontrol/envycontrol.py 
  		sudo mv "${envycontrol_updater_path}"/envycontrol "/usr/share/${__Custom_distro_dir_name}/opt/git/"
  		ln -sf "/usr/share/${__Custom_distro_dir_name}/opt/downloaded/envycontrol/envycontrol.py" "/usr/share/${__Custom_distro_dir_name}/bin/bin/envycontrol"
  	fi
EOF
		chmod +x "${temp_path}"/envycontrol_updater_DmDmDmdMdMdM
	fi
fi
show_m "run isenkram-autoinstall-firmware."
sudo isenkram-autoinstall-firmware || : # to prevent script from exiting "isenkram-autoinstall-firmware contain exit command"

show_m "Configer packages."
apt_purge_with_error2info "${install_autoinstall_firmware[@]}"

if [ "${intel_gpu_exist}" = "true" ];then
sudo mkdir -p /etc/X11/xorg.conf.d/
sudo bash -c 'cat << EOF > /etc/X11/xorg.conf.d/20-intel.conf
Section "Device"
	Identifier  "Intel Graphics"
	Driver      "Intel"
	Option      "AccelMethod"  "sna"
	Option      "TearFree"	"True"
	Option      "Tiling"	"True"
	Option      "SwapbuffersWait" "True"
	#Option      "AccelMethod"  "uxa"
EndSection
EOF'
fi

if [[ "$(CHECK_IF_THIS_LAPTOP)"  = true ]];then
	show_m "some config"
fi

if [[ "${install_GPU_now}" = "install_GPU" ]];then
	mktemp /tmp/GPU_Drivers_ready_XXXXXX
fi
