check_and_download_()
{
	check_this_file_="${1-}"
	new_check_this_file_="${temp_path}/${check_this_file_}"
	check_this_file_location="$(find $HOME -type f -name ${check_this_file_} | head -1)"
	
	if [[ ! -z "${check_this_file_location}" ]];then
		mv "${check_this_file_location}" "${temp_path}"
	fi
	
	if [[ ! -f "${new_check_this_file_}" ]]; then
	show_m "Download $check_this_file_ file from www.github.com/dari862/my_stuff_installer ."
		if curl -SL --progress-bar https://raw.githubusercontent.com/dari862/my_stuff_installer/main/core/"$check_this_file_" -o "${new_check_this_file_}" ;then
		chmod +x "${new_check_this_file_}"
		else
			show_em "Error: Failed to download ${check_this_file_} from ${new_check_this_file_} "
			exit 1
		fi
	fi
}

